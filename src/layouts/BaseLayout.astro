---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import PlayStoreButton from '../components/PlayStoreButton.astro';
import AppStoreButton from '../components/AppStoreButton.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string;
	robots?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, keywords, robots } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} keywords={keywords} robots={robots} />
	</head>
	<body class="min-h-screen studio-dark">
		<nav class="sticky top-0 z-30 nav-glass">
			<div class="px-4 md:px-8 py-4 flex justify-between items-center max-w-6xl mx-auto w-full">
				<a href="/" class="group">
					<BrandLogo variant="nav" />
				</a>
				<div class="flex items-center gap-4 md:gap-6">
					<a href="/#how-it-works" class="hidden md:inline text-[var(--text-muted)] hover:text-[var(--text-main)] text-[10px] font-bold tracking-widest uppercase transition-colors">How it works</a>
					<a href="/#features" class="hidden sm:inline text-[var(--text-muted)] hover:text-[var(--text-main)] text-[10px] font-bold tracking-widest uppercase transition-colors">Features</a>
					<a href="/#pricing" class="hidden sm:inline text-[var(--text-muted)] hover:text-[var(--text-main)] text-[10px] font-bold tracking-widest uppercase transition-colors">Pricing</a>
					<a href="/blog/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] text-[10px] font-bold tracking-widest uppercase transition-colors">Blog</a>
				<div class="flex items-center gap-2 md:gap-3">
					<PlayStoreButton size="nav" />
					<AppStoreButton size="nav" />
				</div>
				</div>
			</div>
		</nav>

		<slot />

		<Footer />
	</body>
</html>
