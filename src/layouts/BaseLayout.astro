---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, PLAY_STORE_URL, STUDIO_NAME } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string;
	robots?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, keywords, robots } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} keywords={keywords} robots={robots} />
	</head>
	<body class="min-h-screen studio-dark">
		<nav class="sticky top-0 z-30 nav-glass">
			<div class="px-4 md:px-8 py-4 flex justify-between items-center max-w-6xl mx-auto w-full">
				<a href="/" class="flex items-center gap-2.5 group">
					<img src="/logo.png" alt={STUDIO_NAME} class="h-8 w-8 object-contain" />
					<span class="text-[11px] font-bold tracking-[0.15em] uppercase text-[var(--text-main)]">{STUDIO_NAME}</span>
				</a>
				<div class="flex items-center gap-5 md:gap-6">
					<a href="/blog/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] text-[10px] font-bold tracking-widest uppercase transition-colors">Blog</a>
					<a href={PLAY_STORE_URL} target="_blank" rel="noopener noreferrer" class="cta-primary px-5 py-2.5 rounded-full text-[10px] font-bold tracking-widest uppercase">Download</a>
				</div>
			</div>
		</nav>

		<slot />

		<Footer />
	</body>
</html>
