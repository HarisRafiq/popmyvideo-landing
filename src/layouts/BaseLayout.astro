---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import BrandLogo from '../components/BrandLogo.astro';
import PlayStoreButton from '../components/PlayStoreButton.astro';
import AppStoreButton from '../components/AppStoreButton.astro';
import { SITE_TITLE, SITE_DESCRIPTION, APP_NAME } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string;
	robots?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, keywords, robots } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} keywords={keywords} robots={robots} />
	</head>
	<body class="min-h-screen studio-dark">
		<nav class="sticky top-0 z-30 nav-glass">
			<div class="site-nav max-w-6xl mx-auto w-full px-3 sm:px-4 md:px-8 py-3 md:py-4">
				<div class="site-nav__inner">
					<a href="/" class="site-nav__logo" aria-label={APP_NAME}>
						<BrandLogo variant="nav" />
					</a>
					<div class="site-nav__actions">
						<a href="/#how-it-works" class="site-nav__link hidden lg:inline">How it works</a>
						<a href="/#features" class="site-nav__link hidden md:inline">Features</a>
						<a href="/#pricing" class="site-nav__link hidden md:inline">Pricing</a>
						<a href="/blog/" class="site-nav__link hidden sm:inline">Blog</a>
						<div class="site-nav__stores">
							<PlayStoreButton size="nav" />
							<AppStoreButton size="nav" />
						</div>
					</div>
				</div>
			</div>
		</nav>

		<slot />

		<Footer />
	</body>
</html>
