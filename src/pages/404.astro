---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_NAME } from '../consts';
---

<BaseLayout 
    title={`404 — Page Not Found | ${APP_NAME}`} 
    description="We couldn't find the page you were looking for. Perhaps it's been moved or deleted."
    robots="noindex, follow"
>
    <main class="min-h-[80vh] flex items-center justify-center px-6 py-24 relative overflow-hidden z-10">
        <div class="absolute top-1/4 -left-20 w-64 h-64 bg-[var(--accent-purple)]/10 rounded-full blur-[100px] animate-pulse"></div>
        <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-[var(--accent-cool)]/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>

        <div class="max-w-2xl w-full text-center relative z-10 fade-up">
            <div class="mb-12 relative inline-block">
                <span class="serif text-[120px] md:text-[180px] leading-none text-white/5 font-bold select-none">404</span>
                <div class="absolute inset-0 flex items-center justify-center">
                    <img src="/logo.png" alt={APP_NAME} class="w-20 h-20 md:w-24 md:h-24 object-contain transform -rotate-6" width="96" height="96" />
                </div>
            </div>

            <h1 class="serif text-4xl md:text-6xl text-[var(--text-main)] mb-6">
                Lost in the <span class="italic text-[var(--text-muted)]">edit.</span>
            </h1>
            
            <p class="text-[var(--text-muted)] text-lg md:text-xl leading-relaxed mb-12 max-w-lg mx-auto">
                We couldn't find the page you were looking for. Let's get you back to PopMyVideo.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a 
                    href="/" 
                    class="w-full sm:w-auto cta-primary font-black px-10 py-5 rounded-2xl md:rounded-3xl active:scale-95 text-[10px] uppercase tracking-[0.2em] cta-glow"
                >
                    Back to Home
                </a>
                <a 
                    href="/blog/" 
                    class="w-full sm:w-auto glass-card text-[var(--text-main)] font-black px-10 py-5 rounded-2xl md:rounded-3xl hover:bg-white/5 transition-all active:scale-95 text-[10px] uppercase tracking-[0.2em]"
                >
                    Read Journal
                </a>
            </div>
        </div>
    </main>
</BaseLayout>
