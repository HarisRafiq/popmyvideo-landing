---
import BaseLayout from '../layouts/BaseLayout.astro';
import StoreCta from '../components/StoreCta.astro';
import { APP_NAME } from '../consts';
---

<BaseLayout
	title={`About ${APP_NAME} — AI Video Editor for Reels & Shorts`}
	description={`${APP_NAME} is the AI video editor that turns raw phone clips into scroll-stopping Reels. Auto captions, VFX, SFX, and smart tracking — timed to your footage. Available on Android and iOS.`}
	keywords="PopMyVideo, AI video editor, auto captions, VFX, SFX, mobile video editor, reels editor, shorts editor"
>
	<main class="max-w-3xl mx-auto px-6 py-12 md:py-24 relative z-10">
		<header class="mb-12 md:mb-16 fade-up">
			<p class="text-[var(--accent-warm)] uppercase tracking-[0.4em] text-[10px] md:text-[11px] font-black mb-4">
				About {APP_NAME}
			</p>
			<h1 class="serif text-4xl md:text-6xl text-[var(--text-main)] mb-6 leading-tight">
				You shoot.<br />
				<span class="italic text-[var(--text-muted)]">AI edits.</span>
			</h1>
			<p class="text-[var(--text-muted)] text-lg md:text-xl leading-relaxed">
				{APP_NAME} is the AI video editor for creators who film on their phone and post the same night. Drop your clip — get captions, VFX, and SFX timed to the action.
			</p>
		</header>

		<div class="prose max-w-none fade-up space-y-6 text-[var(--text-muted)] leading-relaxed">
			<p>
				<strong class="text-[var(--text-main)]">{APP_NAME}</strong> turns raw phone clips into scroll-stopping Reels and Shorts. Upload any clip and AI layers animated text, icons, shapes, and effects on top — timed to what's happening in your footage.
			</p>

			<p>
				Most phone footage looks fine — but fine doesn't stop the scroll. We built {APP_NAME} for creators who want their clips to look finished without spending hours in an editor: auto captions, arrows, sparkle when something lands, and sound effects when the clip needs punch.
			</p>

			<p>
				AI reads your shot (and listens if there's audio), finds the right moments, and adds moving graphics on top. Your original video is never remade — we don't restyle or regenerate your pixels. You import, prompt the vibe, preview versions, and export a polished MP4 from your phone.
			</p>

			<h2 class="serif text-2xl md:text-3xl text-[var(--text-main)] !mt-12 !mb-4">Privacy by design</h2>
			<p>
				Your full video file stays on your device. To generate effects, we send compressed storyboard frames and audio from the selected section — not your entire library. Processing data is deleted after the job completes.
			</p>

			<h2 class="serif text-2xl md:text-3xl text-[var(--text-main)] !mt-12 !mb-4">Where we are today</h2>
			<p>
				{APP_NAME} is live on Android and iOS. We publish practical guides on our <a href="/blog/">blog</a> for creators who want Reels and short-form video to stand out without a steep learning curve.
			</p>
		</div>

		<section class="mt-16 glass-card p-10 md:p-12 text-center">
			<h2 class="serif text-3xl mb-4 text-[var(--text-main)]">Try {APP_NAME} on your next clip</h2>
			<p class="text-[var(--text-muted)] mb-8 max-w-md mx-auto">Download on Android or iOS — polish a clip in minutes, not hours.</p>
			<StoreCta centered />
		</section>
	</main>
</BaseLayout>
