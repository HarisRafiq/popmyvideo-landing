---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_NAME, APP_LAUNCH_INTENT_URL, PLAY_STORE_URL } from '../consts';
---

<BaseLayout
	title={`Reset password — ${APP_NAME}`}
	description={`Set a new ${APP_NAME} password.`}
	robots="noindex, follow"
>
	<main class="min-h-[80vh] relative overflow-hidden pb-24 md:pb-32 z-10">
		<div class="absolute top-1/4 -left-24 w-72 h-72 bg-[var(--accent-warm)]/15 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="absolute bottom-1/3 -right-24 w-96 h-96 bg-[var(--accent-purple)]/10 rounded-full blur-[120px] pointer-events-none"></div>
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(90vw,520px)] h-[min(90vw,520px)] bg-[var(--accent-cool)]/5 rounded-full blur-[80px] pointer-events-none"></div>

		<section class="relative z-10 max-w-xl mx-auto px-6 pt-10 md:pt-14">
			<div class="glass-card p-6 md:p-8">
				<p class="text-[9px] font-black uppercase tracking-widest text-[var(--text-muted)] mb-3">
					Account recovery
				</p>
				<h1 class="serif text-3xl md:text-4xl text-[var(--text-main)] mb-3">
					Set a new password
				</h1>
				<p class="text-[var(--text-muted)] leading-relaxed mb-6">
					If this link is valid, you can choose a new password for your {APP_NAME} account.
				</p>

				<div id="alert" class="hidden rounded-2xl border border-[var(--border-subtle)] bg-white/5 px-4 py-3 mb-6">
					<p id="alert-text" class="text-sm text-[var(--text-muted)] m-0"></p>
				</div>

				<form id="reset-form" class="space-y-4">
					<label class="block">
						<span class="block text-[10px] font-black uppercase tracking-[0.2em] text-[var(--text-muted)] mb-2">New password</span>
						<input
							id="password"
							name="password"
							type="password"
							autocomplete="new-password"
							required
							minlength="8"
							class="w-full rounded-2xl bg-white/5 border border-[var(--border-subtle)] px-4 py-3 text-[var(--text-main)] outline-none focus:border-white/25"
							placeholder="At least 8 characters"
						/>
					</label>

					<label class="block">
						<span class="block text-[10px] font-black uppercase tracking-[0.2em] text-[var(--text-muted)] mb-2">Confirm password</span>
						<input
							id="password2"
							name="password2"
							type="password"
							autocomplete="new-password"
							required
							minlength="8"
							class="w-full rounded-2xl bg-white/5 border border-[var(--border-subtle)] px-4 py-3 text-[var(--text-main)] outline-none focus:border-white/25"
							placeholder="Repeat it"
						/>
					</label>

					<button
						id="submit"
						type="submit"
						class="w-full inline-flex items-center justify-center gap-3 cta-primary font-black px-8 py-4 rounded-2xl active:scale-[0.98] text-[10px] uppercase tracking-[0.2em] cta-glow"
					>
						Update password
					</button>

					<p class="text-[10px] font-bold text-[var(--text-muted)] leading-relaxed m-0">
						This page is only for password recovery. If you didn’t request this, you can safely close it.
					</p>
				</form>

				<div id="next-steps" class="hidden mt-8 pt-6 border-t border-[var(--border-subtle)]">
					<p class="text-[10px] font-black uppercase tracking-[0.25em] text-[var(--text-muted)] mb-4">
						Next step
					</p>
					<div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
						<a
							id="open-app"
							href="/#"
							data-android-intent={APP_LAUNCH_INTENT_URL}
							data-play-store={PLAY_STORE_URL}
							data-desktop-fallback={PLAY_STORE_URL}
							class="inline-flex items-center justify-center gap-3 cta-primary font-black px-8 py-4 rounded-2xl active:scale-[0.98] text-[10px] uppercase tracking-[0.2em] cta-glow w-full sm:w-auto"
						>
							Open {APP_NAME}
						</a>
						<a
							href={PLAY_STORE_URL}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center gap-2 px-6 py-4 rounded-2xl border border-[var(--border-subtle)] text-[var(--text-muted)] font-black text-[10px] uppercase tracking-[0.2em] hover:bg-white/5 transition-colors w-full sm:w-auto"
						>
							Get it on Google Play
						</a>
					</div>
					<p class="text-[10px] font-bold text-[var(--text-muted)] leading-relaxed m-0 mt-4">
						Open the app and sign in with your new password.
					</p>
				</div>
			</div>
		</section>
	</main>

	<script>
		import '../scripts/reset-password';
	</script>
</BaseLayout>

