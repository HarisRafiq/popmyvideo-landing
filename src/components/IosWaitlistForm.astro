---
import { IOS_WAITLIST_SCRIPT_URL } from '../consts';

interface Props {
	id?: string;
}

const { id = 'ios-waitlist' } = Astro.props;
const formId = `${id}-form`;
const emailId = `${id}-email`;
const successId = `${id}-success`;
---

<div id={id} class="ios-waitlist">
	<form id={formId} class="ios-waitlist__form" data-script-url={IOS_WAITLIST_SCRIPT_URL} data-success-id={successId}>
		<input
			type="email"
			id={emailId}
			name="email"
			placeholder="Email for iOS"
			required
			autocomplete="email"
			class="ios-waitlist__input"
		/>
		<button type="submit" class="btn btn-secondary ios-waitlist__submit">
			Notify me
		</button>
	</form>
	<p id={successId} class="ios-waitlist__success hidden" role="status">
		You're on the list — we'll email when iOS is ready.
	</p>
</div>

<style>
	.ios-waitlist {
		width: 100%;
	}

	.ios-waitlist__form {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.5rem;
		width: 100%;
	}

	.ios-waitlist__input {
		min-width: 0;
		padding: 0.8125rem 1rem;
		border-radius: 0.75rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: var(--text-main);
		font: inherit;
		font-size: 0.9375rem;
		outline: none;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.ios-waitlist__input::placeholder {
		color: var(--text-muted);
	}

	.ios-waitlist__input:focus {
		border-color: var(--brand-pink);
		box-shadow: 0 0 0 3px rgba(255, 61, 154, 0.12);
	}

	.ios-waitlist__submit {
		flex-shrink: 0;
	}

	.ios-waitlist__success {
		margin-top: 0.625rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: #34d399;
	}

	.store-cta--center .ios-waitlist__success {
		text-align: center;
	}
</style>

<script>
	document.querySelectorAll<HTMLFormElement>('.ios-waitlist__form').forEach((form) => {
		const scriptURL = form.dataset.scriptUrl;
		const successId = form.dataset.successId;
		if (!scriptURL || !successId) return;

		const successMsg = document.getElementById(successId);
		const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
		if (!successMsg || !emailInput) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			form.style.opacity = '0.5';
			form.style.pointerEvents = 'none';

			try {
				await fetch(scriptURL, {
					method: 'POST',
					mode: 'no-cors',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams({ email: emailInput.value }).toString(),
				});

				form.classList.add('hidden');
				successMsg.classList.remove('hidden');
			} catch {
				form.style.opacity = '1';
				form.style.pointerEvents = 'auto';
				alert('Something went wrong. Please try again.');
			}
		});
	});
</script>
