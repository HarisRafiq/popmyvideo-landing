---
import { IOS_WAITLIST_SCRIPT_URL } from '../consts';

interface Props {
	id?: string;
	variant?: 'hero' | 'cta';
}

const { id = 'ios-waitlist', variant = 'hero' } = Astro.props;
const formId = `${id}-form`;
const emailId = `${id}-email`;
const successId = `${id}-success`;
const isCta = variant === 'cta';
---

<div id={id} class:list={['ios-waitlist', isCta && 'ios-waitlist--cta']}>
	<form id={formId} class="ios-waitlist__form" data-script-url={IOS_WAITLIST_SCRIPT_URL} data-success-id={successId}>
		<input
			type="email"
			id={emailId}
			name="email"
			placeholder="Email for iOS waitlist"
			required
			autocomplete="email"
			class:list={[
				'ios-waitlist__input',
				isCta ? 'ios-waitlist__input--cta' : 'ios-waitlist__input--hero',
			]}
		/>
		<button
			type="submit"
			class:list={[
				'ios-waitlist__button',
				isCta ? 'ios-waitlist__button--cta' : 'ios-waitlist__button--hero',
			]}
		>
			{isCta ? 'Join waitlist' : 'Join iOS waitlist'}
		</button>
	</form>
	<p id={successId} class="ios-waitlist__success hidden" role="status">
		You're on the list — we'll email when iOS is ready.
	</p>
</div>

<style>
	.ios-waitlist__form {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		width: 100%;
	}

	@media (min-width: 640px) {
		.ios-waitlist--cta .ios-waitlist__form {
			flex-direction: row;
			max-width: 28rem;
			margin-inline: auto;
		}

		.ios-waitlist:not(.ios-waitlist--cta) .ios-waitlist__form {
			flex-direction: row;
		}
	}

	.ios-waitlist__input {
		flex: 1;
		min-width: 0;
		border-radius: 1rem;
		outline: none;
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	.ios-waitlist__input--hero {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.12);
		padding: 0.875rem 1.25rem;
		color: #f1f5f9;
		font-size: 0.875rem;
	}

	.ios-waitlist__input--hero::placeholder {
		color: rgba(148, 163, 184, 0.8);
	}

	.ios-waitlist__input--hero:focus {
		border-color: #ff6b35;
		box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.15);
	}

	.ios-waitlist__input--cta {
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		padding: 1rem 1.25rem;
		color: #fff;
		font-size: 0.875rem;
	}

	.ios-waitlist__input--cta::placeholder {
		color: rgba(255, 255, 255, 0.5);
	}

	.ios-waitlist__input--cta:focus {
		border-color: #22d3ee;
		box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.15);
	}

	.ios-waitlist__button {
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 10px;
		border-radius: 1rem;
		transition: background 0.2s, color 0.2s, transform 0.15s;
		white-space: nowrap;
	}

	.ios-waitlist__button:active {
		transform: scale(0.98);
	}

	.ios-waitlist__button--hero {
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: #f1f5f9;
		padding: 0.875rem 1.5rem;
	}

	.ios-waitlist__button--hero:hover {
		border-color: #22d3ee;
		color: #22d3ee;
	}

	.ios-waitlist__button--cta {
		background: rgba(255, 255, 255, 0.95);
		color: #050508;
		padding: 1rem 1.5rem;
	}

	.ios-waitlist__button--cta:hover {
		background: #ff6b35;
		color: #fff;
	}

	.ios-waitlist__success {
		margin-top: 0.75rem;
		font-size: 0.875rem;
		font-weight: 700;
		color: #34d399;
		text-align: center;
	}

	.ios-waitlist--cta .ios-waitlist__success {
		color: #6ee7b7;
	}
</style>

<script>
	document.querySelectorAll<HTMLFormElement>('.ios-waitlist__form').forEach((form) => {
		const scriptURL = form.dataset.scriptUrl;
		const successId = form.dataset.successId;
		if (!scriptURL || !successId) return;

		const successMsg = document.getElementById(successId);
		const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
		if (!successMsg || !emailInput) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			form.style.opacity = '0.5';
			form.style.pointerEvents = 'none';

			try {
				await fetch(scriptURL, {
					method: 'POST',
					mode: 'no-cors',
					headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
					body: new URLSearchParams({ email: emailInput.value }).toString(),
				});

				form.classList.add('hidden');
				successMsg.classList.remove('hidden');
			} catch {
				form.style.opacity = '1';
				form.style.pointerEvents = 'auto';
				alert('Something went wrong. Please try again.');
			}
		});
	});
</script>
