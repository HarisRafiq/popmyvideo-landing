---
import BrandLogo from './BrandLogo.astro';
import StoreCta from './StoreCta.astro';
import { DEVELOPER_NAME, DEVELOPER_LOGO, APP_NAME } from '../consts';
import { FOOTER_CATEGORY_SLUGS, getCategoryBySlug } from '../lib/categories';

const today = new Date();
---

<footer class="border-t border-[var(--border-subtle)] py-12">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
            <div class="space-y-4">
                <BrandLogo variant="footer" />
                <p class="text-sm text-[var(--text-muted)] max-w-xs leading-relaxed">
                    {APP_NAME} by {DEVELOPER_NAME}
                </p>
                <div class="flex flex-wrap gap-x-4 gap-y-1 pt-1">
                    {
                        FOOTER_CATEGORY_SLUGS.map((slug) => {
                            const cat = getCategoryBySlug(slug);
                            return cat ? (
                                <a href={`/blog/category/${cat.slug}/`} class="text-[10px] font-semibold text-[var(--text-muted)] uppercase tracking-widest hover:text-[var(--text-main)] transition-colors">
                                    {cat.title}
                                </a>
                            ) : null;
                        })
                    }
                </div>
                <div class="flex items-center gap-2 pt-1">
                    <a href="https://thinkingcats.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 group">
                        <img src={DEVELOPER_LOGO} alt={DEVELOPER_NAME} class="h-5 w-5 object-contain opacity-60 group-hover:opacity-100 transition-opacity" />
                        <span class="text-[10px] font-semibold text-[var(--text-muted)] uppercase tracking-widest group-hover:text-[var(--text-main)] transition-colors">{DEVELOPER_NAME}</span>
                    </a>
                </div>
            </div>

            <div class="flex flex-col items-start gap-6">
                <StoreCta class="store-cta--start" />
                <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[10px] font-bold uppercase tracking-widest">
                <a href="/blog/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Blog</a>
                <a href="/about/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">About</a>
                <a href="mailto:support@thinkingcats.com" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Support</a>
                <a href="/privacy/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Privacy</a>
                <a href="/terms/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Terms</a>
                </div>
            </div>
        </div>

        <p class="text-[10px] text-[var(--text-muted)] mt-10 opacity-60">
            &copy; {today.getFullYear()} Cats Build Ltd · Office 17907, 182-184 High Street North, East Ham, London E6 2JA
        </p>
    </div>
</footer>
