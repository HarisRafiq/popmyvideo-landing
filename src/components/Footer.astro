---
import { PLAY_STORE_URL, APP_NAME, STUDIO_NAME } from '../consts';

const today = new Date();
---

<footer class="border-t border-[var(--border-subtle)] py-10">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
            <div class="flex items-center gap-3">
                <img src="/logo.png" alt={STUDIO_NAME} class="h-7 w-7 object-contain opacity-80" />
                <p class="text-sm text-[var(--text-muted)]">
                    <span class="text-[var(--text-main)] font-semibold">{APP_NAME}</span> by {STUDIO_NAME}
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[10px] font-bold uppercase tracking-widest">
                <a href={PLAY_STORE_URL} target="_blank" rel="noopener noreferrer" class="text-[var(--accent-warm)] hover:text-[var(--accent-cool)] transition-colors">Google Play</a>
                <a href="/#ios-waitlist" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">iOS waitlist</a>
                <a href="mailto:support@thinkingcats.com" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Support</a>
                <a href="/privacy/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Privacy</a>
                <a href="/terms/" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors">Terms</a>
            </div>
        </div>

        <p class="text-[10px] text-[var(--text-muted)] mt-8 opacity-60">
            &copy; {today.getFullYear()} Cats Build Ltd · Office 17907, 182-184 High Street North, East Ham, London E6 2JA
        </p>
    </div>
</footer>
