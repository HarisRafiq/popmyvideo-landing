---
import PlayStoreButton from './PlayStoreButton.astro';
import AppStoreButton from './AppStoreButton.astro';

interface Props {
	centered?: boolean;
	class?: string;
}

const { centered = false, class: className = '' } = Astro.props;
---

<div class:list={['store-cta', centered && 'store-cta--center', className]}>
	<PlayStoreButton />
	<AppStoreButton />
</div>
