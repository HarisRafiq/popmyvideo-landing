---
import { APP_STORE_URL } from '../consts';

interface Props {
	size?: 'md' | 'nav';
	class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const height = size === 'nav' ? 32 : 44;
const width = Math.round(height * (135 / 40));
---

<a
	href={APP_STORE_URL}
	target="_blank"
	rel="noopener noreferrer"
	class:list={['store-badge', size === 'nav' && 'store-badge--nav', className]}
>
	<img
		src="/badges/app-store.svg"
		alt="Download on the App Store"
		width={width}
		height={height}
		loading={size === 'nav' ? 'eager' : 'lazy'}
		decoding="async"
	/>
</a>
