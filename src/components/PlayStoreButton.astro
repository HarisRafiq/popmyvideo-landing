---
import { PLAY_STORE_URL } from '../consts';

interface Props {
	size?: 'md' | 'nav';
	class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;
---

<a
	href={PLAY_STORE_URL}
	target="_blank"
	rel="noopener noreferrer"
	class:list={['btn', 'btn-primary', size === 'nav' && 'btn-nav', className]}
>
	<svg class="btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
		<path d="M3.609 1.814L13.792 12 3.61 22.186a1.003 1.003 0 0 1-.61-.92V2.734a1.003 1.003 0 0 1 .609-.92zm9.804 8.983l2.109 2.109-9.458 5.498 7.349-7.607zm2.109-2.109l2.108 2.109 2.553-1.486-2.108-2.109-2.553 1.486zm0 4.218l-2.109 2.109 2.553 1.486 2.109-2.109-2.553-1.486zM5.116 20.814l9.458-5.498-2.109-2.109-7.349 7.607z"/>
	</svg>
	Google Play
</a>
