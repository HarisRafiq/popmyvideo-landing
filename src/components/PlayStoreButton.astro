---
import { PLAY_STORE_URL } from '../consts';

interface Props {
	size?: 'md' | 'nav';
	class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const height = size === 'nav' ? 32 : 44;
const width = Math.round(height * (180 / 53.333));
---

<a
	href={PLAY_STORE_URL}
	target="_blank"
	rel="noopener noreferrer"
	class:list={['store-badge', size === 'nav' && 'store-badge--nav', className]}
	onclick={`return gtag_report_conversion('${PLAY_STORE_URL}');`}
>
	<img
		src="/badges/google-play.svg"
		alt="Get it on Google Play"
		width={width}
		height={height}
		loading={size === 'nav' ? 'eager' : 'lazy'}
		decoding="async"
	/>
</a>
